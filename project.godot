; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GameJamProject"
config/description="72-hour game jam — turn-based magical arena with spell-crafting via modifiers."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

EventBus="*res://scripts/infrastructure/event_bus.gd"
MusicDirector="*res://scripts/audio/music/music_director.gd"
RunScore="*res://scripts/infrastructure/run_score.gd"
GameSpeed="*res://scripts/infrastructure/game_speed.gd"
UiTheme="*res://scripts/presentation/ui_theme.gd"
AudioDirector="*res://scripts/infrastructure/audio_director.gd"
FxDirector="*res://scripts/presentation/fx_director.gd"
CorpseManager="*res://scripts/runtime/corpse_manager.gd"
Localization="*res://scripts/infrastructure/localization.gd"
DialogueDB="*res://scripts/core/dialogue/dialogue_database.gd"
DialogueManager="*res://scripts/presentation/dialogue_manager.gd"
LevelDialogueDirector="*res://scripts/runtime/level_dialogue_director.gd"
TurnManager="*res://scripts/core/turn/turn_manager.gd"
StatusRegistry="*res://scripts/core/statuses/status_registry.gd"
AbilityDatabase="*res://scripts/core/abilities/ability_database.gd"
SkillDatabase="*res://scripts/core/skills/skill_database.gd"
SkillOfferController="*res://scripts/runtime/skill_offer_controller.gd"
MoodTracker="*res://scripts/core/narrative/mood_tracker.gd"
BehaviorDatabase="*res://scripts/core/ai/behavior_database.gd"
EnemyAIPlanner="*res://scripts/core/ai/enemy_ai_planner.gd"
CrtPostFx="*res://scenes/presentation/crt_post_fx.tscn"
ActiveLevel="*res://scripts/infrastructure/active_level.gd"
ActiveGame="*res://scripts/infrastructure/active_game.gd"
CampaignController="*res://scripts/runtime/campaign_controller.gd"
StoryCampaignDialogue="*res://scripts/runtime/story_campaign_dialogue.gd"
DummyUpgradeStub="*res://scripts/runtime/_dummy_upgrade_stub.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"

